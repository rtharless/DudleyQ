{{ 'concern-page.css' | asset_url | stylesheet_tag }}

<div class="concern-page">

    <div class="concern-page__image">
        {% if section.settings.image %}
            {{ section.settings.image | image_url: width: 600 | image_tag }}
        {% endif %}
    </div>

    <div class="concern-page__content">

        <p class="concern-page__eyebrow">
            {{ section.settings.eyebrow }}
        </p>

        <h2>
            {{ section.settings.concern_heading }}
        </h2>

        <div class="concern-buttons">
            {% for block in section.blocks %}
                <a href="{{ routes.all_products_collection_url }}?filter.p.m.custom.concern={{ block.settings.filter_value | url_encode | replace: '+', '%20' }}"
                    class="concern-button"
                    data-index="{{ forloop.index0 }}">

                      {% if block.settings.card_image %}
                          {{ block.settings.card_image | image_url: width: 600 | image_tag }}
                          <span>{{ block.settings.title }}</span>
                      {% else %}
                        {{ block.settings.title }}    
                      {% endif %}
                </a>
            {% endfor %}
        </div>

        <span class="concern__heading">
          {{ section.settings.heading }}
        </span>

        <div class="concern-page__description">
            {{ section.settings.description }}
        </div>
        
        <div class="second-block">
            <div class="concern-card">

                <div class="concern-card__image">
                    {%  if section.settings.quiz_image %}
                        {{ section.settings.quiz_image
                            | image_url: width: 600
                            | image_tag
                        }}
                    {% endif %}
                </div>
            
                <div class="concern-card__content">
            
                    <span id="concern-card-title" class="uppercase">
                        {{ section.settings.concern_card_title }}
                    </span>
            
                    <p id="concern-card-description">
                        {{ section.settings.concern_card_desc }}
                    </p>
            
                    <a
                        id="concern-card-link"
                        href="#"
                        class="concern-card__button">
                        Take Quiz
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </div>
            <span class="concern-card__arrow">
                &gt;
            </span>
        </div>
        
    </div>

</div>

{% schema %}
{
  "name": "Concern Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "CONCERN PAGE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Perfect Match"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Not sure where to start? Answer a few questions and we'll match you to the right products."
    },
    {
      "type": "text",
      "id": "concern_heading",
      "label": "Concern Heading",
      "default": "Shop by Concern"
    },
    {
        "type": "image_picker",
        "id": "quiz_image",
        "label": "Quiz Card Image"
    },
    {
        "type": "text",
        "id": "concern_card_title",
        "label": "Concern Card Title",
        "default": "Not sure where to start?"
    },
    {
        "type": "text",
        "id": "concern_card_desc",
        "label": "Concern Card Description",
        "default": "Take our hair quiz and we'll match you to the right routine for your concerns."
    }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Concern",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "filter_value",
          "label": "Filter Value"
        },
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Image"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Concern Page",
      "blocks": [
        {
          "type": "concern",
          "settings": {
            "title": "Breakage",
            "filter_value":"Breakage"
          }
        },
        {
          "type": "concern",
          "settings": {
            "title": "Curl Definition",
            "filter_value":"Curl Definition"
          }
        },
        {
          "type": "concern",
          "settings": {
            "title": "Damage Repair",
            "filter_value":"Damage Repair"
          }
        },
        {
          "type": "concern",
          "settings": {
            "title": "Dryness",
            "filter_value":"Dryness"
          }
        },
        {
          "type": "concern",
          "settings": {
            "title": "Frizz",
            "filter_value":"Frizz"
          }
        },
        {
          "type": "concern",
          "settings": {
            "title": "Growth",
            "filter_value":"Growth"
          }
        },
        {
          "type": "concern",
          "settings": {
            "title": "Irritation",
            "filter_value":"Irritation"
          }
        },
        {
            "type": "concern",
            "settings": {
                "title": "Oiliness",
                "filter_value":"Oiliness"
            }
        },
        {
          "type": "concern",
          "settings": {
              "title": "Scalp Health",
              "filter_value":"Scalp Health"
          }
        },
        {
          "type": "concern",
          "settings": {
              "title": "Thinning",
              "filter_value":"Thinning"
          }
        }
      ]
    }
  ]
}
{% endschema %}