<div class="routine-page">

    <div class="routine-page__image">
        {% if section.settings.image %}
            {{ section.settings.image | image_url: width: 1200 | image_tag }}
        {% endif %}
    </div>

    <div class="routine-page__content">

        <p class="routine-page__eyebrow">
            {{ section.settings.eyebrow }}
        </p>

        <h1>
            {{ section.settings.heading }}
        </h1>

        <div class="routine-page__description">
            {{ section.settings.description }}
        </div>

        <h2>
            {{ section.settings.routine_heading }}
        </h2>

        <div class="routine-buttons">
                <button
                    class="routine-button uppercase">
                    Classics
                </button>
                <button
                    class="routine-button uppercase">
                    Confident Curls
                </button>
                <button
                    class="routine-button uppercase">
                    Healthy Tresses
                </button>
                <button
                    class="routine-button uppercase">
                    Length & Strength
                </button>
                <button
                    class="routine-button uppercase">
                    Moisture Matters
                </button>
                <button
                    class="routine-button uppercase">
                    Revival
                </button>
                <button
                    class="routine-button uppercase">
                    Soothe Calm
                </button>
        
        </div>

        <div id="routine-card">
    
        </div>

    </div>

</div>

{% schema %}
{
  "name": "Routine Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "ROUTINE PAGE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Perfect Match"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Not sure where to start? Answer a few questions and we'll match you to the right products."
    },
    {
      "type": "text",
      "id": "routine_heading",
      "label": "Routine Heading",
      "default": "Shop By Routine"
    }
  ],
  "presets": [
    {
      "name": "Routine Page"
    }
  ]
}
{% endschema %}