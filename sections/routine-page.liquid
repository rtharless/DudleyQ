{{ 'routine-page.css' | asset_url | stylesheet_tag }}

<div class="routine-page">

    <div class="routine-page__image">
        {% if section.settings.image %}
            {{ section.settings.image | image_url: width: 600 | image_tag }}
          {% else %}
            <img
                src="{{ 'routine-placeholder.webp' | asset_url }}"
                alt="Routine placeholder"
                loading="lazy"
                width="600"
                height="600">
          {% endif %}
    </div>

    <div class="routine-page__content">

        <p class="routine-page__eyebrow">
            {{ section.settings.eyebrow }}
        </p>

        <span class="routine__heading">
            {{ section.settings.heading }}
        </span>

        <div class="routine-page__description">
            {{ section.settings.description }}
        </div>

        <h2>
            {{ section.settings.routine_heading }}
        </h2>

        <div class="routine-buttons">
                <button
                    class="routine-button uppercase">
                    <strong>Classics</strong>
                </button>
                <button
                    class="routine-button uppercase">
                    <strong>Confident Curls</strong>
                </button>
                <button
                    class="routine-button uppercase">
                    <strong>Healthy Tresses</strong>
                </button>
                <button
                    class="routine-button uppercase">
                    <strong>Length & Strength</strong>
                </button>
                <button
                    class="routine-button uppercase">
                    <strong>Moisture Matters</strong>
                </button>
                <button
                    class="routine-button uppercase">
                    <strong>Revival</strong>
                </button>
                <button
                    class="routine-button uppercase">
                    <strong>Soothe Calm</strong>
                </button>
        
        </div>
        <div class="second-block">
            <div class="routine-card">

                <div class="routine-card__image">
                    {% if section.settings.card_image %}
                        {{ section.settings.card_image | image_url: image_tag }}
                    {% else %}
                        <img
                            src="{{ 'routine-placeholder.webp' | asset_url }}"
                            alt="Routine placeholder"
                            loading="lazy"
                            width="600"
                            height="600">
                    {% endif %}
                </div>
            
                <div class="routine-card__content">
            
                    <span id="routine-card-title" class="uppercase">
                        {{ section.settings.routine_card_title }}
                    </span>
            
                    <p id="routine-card-description">
                        {{ section.settings.routine_card_desc }}
                    </p>
            
                    <a
                        id="routine-card-link"
                        href="#"
                        class="routine-card__button">
                        Take Quiz
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </div>
            <span class="routine-card__arrow">
                &gt;
            </span>
        </div>
    </div>

</div>

{% schema %}
{
  "name": "Routine Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "ROUTINE PAGE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Perfect Match"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Not sure where to start? Answer a few questions and we'll match you to the right products."
    },
    {
      "type": "text",
      "id": "routine_heading",
      "label": "Routine Heading",
      "default": "Shop By Routine"
    },
    {
        "type": "image_picker",
        "id": "card_image",
        "label": "Routine Card Image"
    },
    {
        "type": "text",
        "id": "routine_card_title",
        "label": "Routine Card Title",
        "default": "Hair Type"
    },
    {
        "type": "text",
        "id": "routine_card_desc",
        "label": "Routine Card Description",
        "default": "The best products and routine for your hair."
    },
  ],
  "presets": [
    {
      "name": "Routine Page"
    }
  ]
}
{% endschema %}